))\n            print(f\"  step {step:6d}/{steps}  \"\n                  f\"loss={avg_loss:.4f}  \"\n                  f\"elapsed={elapsed/60:.1f}min  \"\n                  f\"steps/s={step/elapsed:.1f}\")\n\n        if step % C.save_every == 0:\n            params_cpu = jax_utils.unreplicate(state).params\n            import flax.serialization as fser\n            with open(C.ckpt_path, \"wb\") as f:\n                f.write(fser.to_bytes(params_cpu))\n            print(f\"  💾  Checkpoint → {C.ckpt_path}\")\n\n    # Return unreplicated state for inference\n    final_state = jax_utils.unreplicate(state)\n    print(f\"\\nTraining complete.  Final loss: {losses[-1]:.4f}\")\n\n    # Loss curve\n    plt.figure(figsize=(9, 3))\n    plt.plot(losses, lw=0.8, color=\"#2a6b8a\")\n    plt.xlabel(\"Step\"); plt.ylabel(\"MSE Loss\")\n    plt.title(\"Diffusion Training Loss\")\n    plt.tight_layout()\n    plt.savefig(C.output_dir / \"loss_curve.png\", dpi=120)\n    plt.show()\n\n    return final_state\n\n\n# Run (set steps=200 for a quick smoke-test; 50k for real training)\ntrained_state = train(steps=500)   # ← increase for real training\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-20T10:53:52.149372Z","iopub.execute_input":"2026-04-20T10:53:52.149561Z","iopub.status.idle":"2026-04-20T10:57:59.387666Z","shell.execute_reply.started":"2026-04-20T10:53:52.149543Z","shell.execute_reply":"2026-04-20T10:57:59.386324Z"}},"outputs":[{"name":"stdout","text":"\nTraining for 500 steps…\n  step    500/500  loss=0.2706  elapsed=2.8min  steps/s=2.9\n\nTraining complete.  Final loss: 0.0728\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<Figure size 900x300 with 1 Axes>","image/png":""},"metadata":{}}],"execution_count":17},{"cell_type":"code","source":"# ──────────────────────────────────────────────────────────────\n# DDIM Sampler (from scratch)\n#\n#  DDPM reverse step (stochastic):\n#    x_{t-1} = μ_θ(x_t, t) + σ_t · z\n#\n#  DDIM reverse step (Song et al. 2020, deterministic if η=0):\n#    x_{t-1} = sqrt(ᾱ_{t-1}) · (x_t - sqrt(1-ᾱ_t)·ε_θ) / sqrt(ᾱ_t)\n#            + sqrt(1-ᾱ_{t-1} - σ²) · ε_θ\n#            + σ · z\n#  where σ = η · sqrt((1-ᾱ_{t-1})/(1-ᾱ_t)) · sqrt(1-ᾱ_t/ᾱ_{t-1})\n# ──────────────────────────────────────────────────────────────\n\ndef ddim_sample_step(params, x_t, t_idx, t_prev_idx,\n                     sched, eta=0.0, rng=None):\n    \"\"\"\n    One DDIM reverse step.\n    t_idx, t_prev_idx : integer scalars (Python int)\n    x_t               : (B, H, W, C)\n    \"\"\"\n    t_batch = jnp.full((x_t.shape[0],), t_idx, dtype=jnp.int32)\n    eps_pred = model.apply({\"params\": params}, x_t, t_batch)\n\n    ab_t    = sched[\"alphas_bar\"][t_idx]\n    ab_prev = sched[\"alphas_bar\"][t_prev_idx] if t_prev_idx >= 0 else 1.0\n\n    # predicted x_0\n    x0_pred = (x_t - jnp.sqrt(1 - ab_t) * eps_pred) / jnp.sqrt(ab_t)\n    x0_pred = jnp.clip(x0_pred, -1, 1)\n\n    # direction pointing to x_t\n    sigma = (eta\n             * jnp.sqrt((1 - ab_prev) / (1 - ab_t))\n             * jnp.sqrt(1 - ab_t / ab_prev))\n    dir_xt = jnp.sqrt(1 - ab_prev - sigma**2) * eps_pred\n\n    noise  = random.normal(rng, x_t.shape) if (rng is not None and eta > 0) else 0.0\n    x_prev = jnp.sqrt(ab_prev) * x0_pred + dir_xt + sigma * noise\n    return x_prev\n\n\ndef ddim_sample(params, shape, rng,\n                ddim_steps=C.ddim_steps,\n                eta=C.eta,\n                sched=SCHED) -> jnp.ndarray:\n    \"\"\"\n    Full reverse diffusion: pure noise → image.\n    shape : (B, H, W, C)\n    \"\"\"\n    rng, noise_rng = random.split(rng)\n    x = random.normal(noise_rng, shape)\n\n    # Pick a subsequence of timesteps (skip-steps for speed)\n    timesteps = np.linspace(C.T - 1, 0, ddim_steps + 1, dtype=int)\n\n    for i in tqdm(range(len(timesteps) - 1), desc=\"DDIM sampling\", leave=False):\n        t_idx      = int(timesteps[i])\n        t_prev_idx = int(timesteps[i + 1])\n        rng, step_rng = random.split(rng)\n        x = ddim_sample_step(params, x, t_idx, t_prev_idx,\n                             sched, eta=eta, rng=step_rng)\n    return x\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-20T10:57:59.388963Z","iopub.execute_input":"2026-04-20T10:57:59.389169Z","iopub.status.idle":"2026-04-20T10:57:59.396202Z","shell.execute_reply.started":"2026-04-20T10:57:59.389151Z","shell.execute_reply":"2026-04-20T10:57:59.395288Z"}},"outputs":[],"execution_count":18},{"cell_type":"code","source":"# ──────────────────────────────────────────────────────────────\n# Img2img pipeline (Van Gogh style transfer)\n#\n#  1. Encode input image  x_0 ∈ [-1, 1]\n#  2. Compute t* = round(strength · T)  (how far to diffuse)\n#  3. Forward diffuse to t*:  x_{t*} = q_sample(x_0, t*)\n#  4. Reverse-diffuse from t* → 0 with DDIM\n# ──────────────────────────────────────────────────────────────\n\ndef img2img(params, image: np.ndarray,\n            strength: float = C.img2img_strength,\n            rng=None,\n            ddim_steps: int = C.ddim_steps,\n            eta: float = C.eta) -> np.ndarray:\n    \"\"\"\n    image   : (H, W, 3) uint8 [0,255] OR float32 [-1,1]\n    returns : (H, W, 3) uint8 [0,255]\n    \"\"\"\n    if rng is None:\n        rng = random.PRNGKey(42)\n\n    # Preprocess\n    if image.dtype == np.uint8:\n        x0 = jnp.array(image / 127.5 - 1.0, dtype=jnp.float32)\n    else:\n        x0 = jnp.array(image, dtype=jnp.float32)\n    x0 = x0[None]   # add batch dim → (1, H, W, C)\n\n    # Resize to model resolution\n    H, W = C.image_size, C.image_size\n    x0 = jax.image.resize(x0, (1, H, W, 3), method=\"lanczos3\")\n\n    # Compute noise level t*\n    t_star = int(strength * (C.T - 1))\n    t_batch = jnp.array([t_star])\n\n    # Forward diffuse to t*\n    rng, n_rng = random.split(rng)\n    noise = random.normal(n_rng, x0.shape)\n    x_t   = q_sample(x0, t_batch, noise, SCHED)\n\n    # DDIM reverse from t* → 0\n    # Build a subsequence that starts at t*\n    n_steps   = max(1, int(ddim_steps * strength))\n    timesteps = np.linspace(t_star, 0, n_steps + 1, dtype=int)\n\n    x = x_t\n    for i in tqdm(range(len(timesteps) - 1),\n                  desc=f\"Denoising (t={t_star}→0)\", leave=False):\n        t_idx      = int(timesteps[i])\n        t_prev_idx = int(timesteps[i + 1])\n        rng, step_rng = random.split(rng)\n        x = ddim_sample_step(params, x, t_idx, t_prev_idx,\n                             SCHED, eta=eta, rng=step_rng)\n\n    # Postprocess\n    out = np.array(jnp.clip((x[0] + 1) / 2 * 255, 0, 255), dtype=np.uint8)\n    return out","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-20T10:57:59.396746Z","iopub.execute_input":"2026-04-20T10:57:59.396917Z","iopub.status.idle":"2026-04-20T10:57:59.420205Z","shell.execute_reply.started":"2026-04-20T10:57:59.396902Z","shell.execute_reply":"2026-04-20T10:57:59.419355Z"}},"outputs":[],"execution_count":19},{"cell_type":"code","source":"# ──────────────────────────────────────────────────────────────\n# Interactive inference UI (Kaggle widget)\n# ──────────────────────────────────────────────────────────────\n\ndef show_result(original: np.ndarray, stylised: np.ndarray,\n                save_path=None):\n    fig, axes = plt.subplots(1, 2, figsize=(12, 5),\n                             facecolor=\"#1c2733\")\n    titles = [\"Original\", \"Van Gogh Style ✦\"]\n    imgs   = [original, stylised]\n    for ax, title, img in zip(axes, titles, imgs):\n        ax.imshow(img)\n        ax.set_title(title, color=\"#e8d5a3\", fontsize=14,\n                     fontweight=\"bold\", fontfamily=\"serif\")\n        ax.axis(\"off\")\n    fig.suptitle(\"From-Scratch JAX Diffusion  •  Post-Impressionist Style\",\n                 color=\"#f0e0a0\", fontsize=14, fontfamily=\"serif\")\n    plt.tight_layout()\n    if save_path:\n        fig.savefig(save_path, dpi=150, bbox_inches=\"tight\",\n                    facecolor=fig.get_facecolor())\n   