rainA under whatever structure the zip used\n    candidates = sorted(download_path.rglob(\"trainA\"))\n    if candidates:\n        print(f\"trainA found at: {candidates[0]}\")\n        return candidates[0]\n\n    print(\"Download succeeded but trainA not found — returning root for recursive scan\")\n    return download_path\n\n\ndef load_images_from_dir(directory: Path, size: int, patches_per_image: int = 16):\n    \"\"\"Recursively walks a directory and extracts random square patches.\"\"\"\n    if not directory or not directory.exists():\n        print(f\"  Directory not found: {directory}\")\n        return None\n\n    extensions = {'.jpg', '.jpeg', '.png', '.webp'}\n    image_paths = [p for p in directory.rglob('*') if p.suffix.lower() in extensions]\n\n    if not image_paths:\n        print(f\"  No images found in {directory}\")\n        return None\n\n    patches = []\n    skipped = 0\n    print(f\"  -> Extracting patches from {len(image_paths)} images...\")\n\n    for p in image_paths:\n        try:\n            with Image.open(p) as img:\n                img = img.convert(\"RGB\")\n                w, h = img.size\n                if w < size or h < size:\n                    skipped += 1\n                    continue\n                for _ in range(patches_per_image):\n                    left = np.random.randint(0, w - size + 1)\n                    top  = np.random.randint(0, h - size + 1)\n                    patch = img.crop((left, top, left + size, top + size))\n                    patch_arr = (np.array(patch).astype(np.float32) / 127.5) - 1.0\n                    patches.append(patch_arr)\n        except Exception as e:\n            print(f\" Skipping {p.name}: {e}\")\n            continue\n\n    if skipped:\n        print(f\" Skipped {skipped} images smaller than {size}x{size}\")\n\n    return np.array(patches) if patches else None\n\n\ndef build_dataset(size: int = C.image_size) -> np.ndarray:\n    print(\"=\" * 56)\n    print(\"  AUTONOMOUS DATA LOA