f\"steps={steps_sl.value}  \"\n                  f\"η={eta_sl.value}  seed={seed_box.value}\")\n\n            rng    = random.PRNGKey(seed_box.value)\n            result = img2img(\n                trained_state.params,\n                img_model,\n                strength   = strength_sl.value,\n                rng        = rng,\n                ddim_steps = steps_sl.value,\n                eta        = eta_sl.value,\n            )\n\n            # Upsample result back to display size\n            result_big = np.array(\n                Image.fromarray(result).resize(display_size, Image.LANCZOS)\n            )\n\n            out_path = C.output_dir / f\"{Path(fname).stem}_vangogh.png\"\n            Image.fromarray(result_big).save(out_path)\n            show_result(img_disp, result_big,\n                        save_path=C.output_dir / f\"{Path(fname).stem}_compare.png\")\n            print(f\"Saved → {out_path}\")\n\n    run_btn.on_click(on_run)\n\n    display(widgets.VBox([\n        widgets.HTML(\"<h3 style='font-family:serif;color:#5b8fa8'>\"\n                     \"JAX Diffusion — Van Gogh Style Transfer</h3>\"),\n        uploader,\n        widgets.HBox([strength_sl, steps_sl]),\n        widgets.HBox([eta_sl, seed_box]),\n        run_btn, out_area,\n    ]))\n\nexcept Exception as e:\n    print(f\"Widget unavailable ({e}) — using script mode.\")\n\n    # ── Script-mode fallback ──────────────────────────────────\n    IMAGE_PATH = \"/kaggle/input/YOUR_DATASET/your_photo.jpg\"\n    # ↑  Change this path to a real image\n\n    if Path(IMAGE_PATH).exists():\n        img = np.array(Image.open(IMAGE_PATH).convert(\"RGB\")\n                       .resize((C.image_size, C.image_size), Image.LANCZOS))\n        rng    = random.PRNGKey(0)\n        result = img2img(trained_state.params, img, rng=rng)\n        show_result(img, result,\n                    save_path=C.output_dir / \"vangogh_result.png\")\n    else:\n        # Pure generation demo (no input image)\n        print(\"Generating a sample from pure noise…\")\n        rng    = random.PRNGKey(7)\n        sample = ddim_sample(trained_state.params,\n                             (1, C.image_size, C.image_size, C.channels),\n                             rng)\n        sample_img = np.array(\n            jnp.clip((sample[0] + 1) / 2 * 255, 0, 255), dtype=np.uint8\n        )\n        Image.fromarray(sample_img).save(C.output_dir / \"generated_sample.png\")\n        plt.imshow(sample_img); plt.axis(\"off\")\n        plt.title(\"Generated sample (untrained — upload data to train)\")\n        plt.show()\n\n\n# ──────────────────────────────────────────────────────────────\n# Model summary\n# ──────────────────────────────────────────────────────────────\n\ndef model_summary():\n    params = trained_state.params\n    total  = sum(x.size for x in jax.tree_util.tree_leaves(params))\n    print(\"=\" * 52)\n    print(\"  From-Scratch JAX Diffusion Model Summary\")\n    print(\"=\" * 52)\n    print(f\"  Image size        : {C.image_size}×{C.image_size}×{C.channels}\")\n    print(f\"  UNet base ch      : {C.base_channels}\")\n    print(f\"  Channel mults     : {C.channel_mults}\")\n    print(f\"  Res blocks/level  : {C.num_res_blocks}\")\n    print(f\"  Attn resolutions  : {C.attn_resolutions}\")\n    print(f\"  Total parameters  : {total/1e6:.2f}M\")\n    print(f\"  Noise schedule    : {C.beta_schedule}  T={C.T}\")\n    print(f\"  DDIM steps        : {C.ddim_steps}  η={C.eta}\")\n    print(f\"  Img2img strength  : {C.img2img_strength}\")\n    print(f\"  TPU devices       : {NUM_DEVICES}\")\n    print(\"=\" * 52)\n\nmodel_summary()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-20T10:57:59.420602Z","iopub.execute_input":"2026-04-20T10:57:59.420756Z","iopub.status.idle":"2026-04-20T10:57:59.45049Z","shell.execute_reply.started":"2026-04-20T10:57:59.420743Z","shell.execute_reply":"2026-04-20T10:57:59.449726Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"