metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-20T10:50:57.779191Z","iopub.execute_input":"2026-04-20T10:50:57.779346Z","iopub.status.idle":"2026-04-20T10:50:57.798082Z","shell.execute_reply.started":"2026-04-20T10:50:57.779332Z","shell.execute_reply":"2026-04-20T10:50:57.797387Z"}},"outputs":[],"execution_count":8},{"cell_type":"code","source":"# ──────────────────────────────────────────────────────────────\n# Noise Schedule\n#\n#  Forward process:  q(x_t | x_0) = N(sqrt(ᾱ_t)·x_0, (1−ᾱ_t)·I)\n#  We precompute β_t, α_t = 1−β_t, ᾱ_t = Π α_s\n# ──────────────────────────────────────────────────────────────\n\ndef make_schedule(T: int, beta_start: float, beta_end: float,\n                  schedule: str = \"cosine\") -> dict:\n    \"\"\"\n    Returns a dict of precomputed diffusion quantities as jnp arrays.\n    All shapes: (T,).\n    \"\"\"\n    if schedule == \"linear\":\n        betas = jnp.linspace(beta_start, beta_end, T, dtype=jnp.float32)\n\n    elif schedule == \"cosine\":\n        # Nichol & Dhariwal (2021) cosine schedule\n        # ᾱ_t = cos²((t/T + s)/(1+s) · π/2)  where s=0.008\n        s = 0.008\n        steps = T + 1\n        t = jnp.linspace(0, T, steps, dtype=jnp.float32)\n        alphas_bar = jnp.cos(((t / T) + s) / (1 + s) * math.pi / 2) ** 2\n        alphas_bar = alphas_bar / alphas_bar[0]\n        betas = 1 - (alphas_bar[1:] / alphas_bar[:-1])\n        betas = jnp.clip(betas, 0, 0.999)\n    else:\n        raise ValueError(schedule)\n\n    alphas         = 1.0 - betas\n    alphas_bar     = jnp.cumprod(alphas)\n    alphas_bar_prev = jnp.concatenate([jnp.array([1.0]), alphas_bar[:-1]])\n\n    sqrt_ab        = jnp.sqrt(alphas_bar)\n    sqrt_one_m_ab  = jnp.sqrt(1.0 - alphas_bar)\n\n    # Posterior q(x_{t-1}|x_t, x_0)\n    posterior_var  = betas * (1 - alphas_bar_prev) / (1 - alphas_bar)\n    posterior_mean_c1 = (betas * jnp.sqrt(alphas_bar_prev) / (1 - alphas_bar))\n    posterior_mean_c2 = ((1 - alphas_bar_prev) * jnp.sqrt(alphas) / (1 - alphas_bar))\n\n    return dict(\n        betas=betas,\n        alphas=alphas,\n        alphas_bar=alphas_bar,\n        alphas_bar_prev=alphas_bar_prev,\n        sqrt_ab=sqrt_ab,\n        sqrt_one_m_ab=sqrt_one_m_ab,\n        posterior_var=posterior_var,\n        posterior_mean_c1=posterior_mean_c1,\n        posterior_mean_c2=posterior_mean_c2,\n    )\n\nSCHED = make_schedule(C.T, C.beta_start, C.beta_end, C.beta_schedule)\nprint(f\"Schedule '{C.beta_schedule}': \"\n      f\"β₀={SCHED['betas'][0]:.5f}  β_T={SCHED['betas'][-1]:.5f}  \"\n      f\"ᾱ_T={SCHED['alphas_bar'][-1]:.5f}\")\n\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-20T10:50:57.798517Z","iopub.execute_input":"2026-04-20T10:50:57.798662Z","iopub.status.idle":"2026-04-20T10:50:57.830272Z","shell.execute_reply.started":"2026-04-20T10:50:57.798648Z","shell.execute_reply":"2026-04-20T10:50:57.829414Z"}},"outputs":[{"name":"stdout","text":"Schedule 'cosine': β₀=0.00004  β_T=0.99900  ᾱ_T=0.00000\n","output_type":"stream"}],"execution_count":9},{"cell_type":"code","source":"# ──────────────────────────────────────────────────────────────\n# CELL 5 — Forward diffusion (training helper)\n#\n#  x_t = sqrt(ᾱ_t)·x_0 + sqrt(1−ᾱ_t)·ε,   ε ~ N(0,I)\n# ──────────────────────────────────────────────────────────────\n\ndef q_sample(x0: jnp.ndarray, t: jnp.ndarray,\n             noise: jnp.ndarray, sched: dict) -> jnp.ndarray:\n    \"\"\"\n    Diffuse a batch of clean images x0 to timestep t.\n    x0   : (B, H, W, C)  in [-1, 1]\n    t    : (B,)           int32 timestep indices\n    noise: (B, H, W, C)   standard normal\n    \"\"\"\n    sqrt_ab    = sched[\"sqrt_ab\"][t][:, None, None, None]\n    sqrt_1m_ab = sched[\"sqrt_one_m_ab\"][t][:, None, None, None]\n    return sqrt_ab * x0 + sqrt_1m_ab * noise","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-20T10:50:57.830713Z","iopub.execute_input":"2026-04-20T10:50:57.830881Z","iopub.status.idle":"2026-04-20T10:50:57.848184Z","shell.execute_reply.started":"2026-04-20T10:50:57.830866Z","shell.execute_reply":"2026-04-20T10:50:57.847421Z"}},"outputs":[],"execution_count":10},{"cell_type":"code","source":"# ──────────────────────────────────────────────────────────────\n# UNet building blocks\n# ──────────────────────────────────────────────────────────────\n\n# ── 6a. Sinusoidal timestep embedding ─────────────────────────\n\ndef sinusoidal_embedding(t: jnp.ndarray, dim: int) -> jnp.ndarray:\n    \"\"\"\n    t   : (B,) float or int\n    out : (B, dim)\n    Identical to the Transformer positional encoding formula.\n    \"\"\"\n    assert dim % 2 == 0\n    half = dim // 2\n    freqs = jnp.exp(\n        -math.log(10000) * jnp.arange(half, dtype=jnp.float32) / (half - 1)\n    )\n    args  = t[:, None].astype(jnp.float32) * freqs[None]\n    return jnp.concatenate([jnp.sin(args), jnp.cos(args)], axis=-1)\n\n\n# ── 6b. Time-embedding MLP ────────────────────────────────────\n\nclass TimeEmbedding(nn.Module):\n    dim: int\n\n    @nn.compact\n    def __call__(self, t):\n        x = sinusoidal_embedding(t, self.dim)\n        x = nn.Dense(self.dim * 4)(x)\n        x = nn.swish(x)\n        x = nn.Dense(self.dim * 4)(x)\n        return x\n\n\n# ── 6c. ResBlock ──────────────────────────────────────────────\n\nclass ResBlock(nn.Module):\n    out_ch:   int\n    dropout:  float = 0.1\n    use_scale_shift_norm: bool = True   # better conditioning\n\n    @nn.compact\n    def __call__(self, x, temb, deterministic=True):\n        B, H, W, in_ch = x.shape   # renamed C→in_ch to avoid shadowing Config\n        h = nn.GroupNorm(num_groups=32)(x)\n        h = nn.swish(h)\n        h = nn.Conv(self.out_ch, (3, 3), padding=\"SAME\")(h)\n\n        # inject timestep\n        temb_proj = nn.Dense(self.out_ch * 2 if self.use_scale_shift_norm\n                             else self.out_ch)(nn.swish(temb))\n        temb_proj = temb_proj[:, None, None, :]   # broadcast over H,W\n\n        if self.use_scale_shift_norm:\n            scale, shift = jnp.split(temb_proj, 2, axis=-1)\n            h = nn.GroupNorm(num_groups=32)(h) * (1 + scale) + shift\n        else:\n            h = nn.GroupNorm(num_groups=32)(h + temb_proj)\n\n        h = nn.swish(h)\n        h = nn.Dropout(rate=self.dropout)(h, deterministic=deterministic)\n        h = nn.Conv(self.out_ch, (3, 3), padding=\"SAME\",\n                    kernel_init=nn.initializers.zeros)(h)\n\n        # skip connection with optional projection\n        if in_ch != self.out_ch:\n            x = nn.Conv(self.out_ch, (1, 1))(x)\n        return x + h\n\n\n# ── 6d. Self-attention block ──────────────────────────────────\n\nclass SelfAttention(nn.Module):\n    num_heads: int = 8\n\n    @nn.compact\n    def __call__(self, x):\n        B, H, W, ch = x.shape   # renamed C→ch\n        h = nn.GroupNorm(num_groups=32)(x)\n        h = h.reshape(B, H * W, ch)\n        h = nn.MultiHeadDotProductAttention(\n            num_heads=self.num_heads,\n            qkv_features=ch,\n            out_features=ch,\n            kernel_init=nn.initializers.xavier_uniform(),\n        )(h, h)\n        h = h.reshape(B, H, W, ch)\n        return x + h\n\n\n# ── 6e. Down / Up sampling ────────────────────────────────────\n\nclass Downsample(nn.Module):\n    out_ch: int\n\n    @nn.compact\n    def __call__(self, x):\n        # strided convolution — better than avg-pool for generative models\n        return nn.Conv(self.out_ch, (3, 3), strides=(2, 2), padding=\"SAME\")(x)\n\n\nclass Upsample(nn.Module):\n    out_ch: int\n\n    @nn.compact\n    def __call__(self, x):\n        B, H, W, ch = x.shape   # renamed C→ch\n        x = jax.image.resize(x, (B, H * 2, W * 2, ch), method=\"nearest\")\n        return nn.Conv(self.out_ch, (3, 3), padding=\"SAME\")(x)\n\n\n# ── 6f. UNet ──────────────────────────────────────────────────\n\nclass UNet(nn.Module):\n    \"\"\"\n    Time-conditioned UNet that predicts the noise ε given (x_t, t).\n\n    Architecture (DDPM / improved-DDPM style):\n      Encoder  → [ResBlock, (Attn,) ResBlock, Downsample] × levels\n      Bottleneck → ResBlock, Attn, ResBlock\n      Decoder  → [Upsample, ResBlock, (Attn,) ResBlock] × levels (skip-connected)\n    \"\"\"\n    base_ch:         int            = 128\n    ch_mults:        Sequence[int]  = (1, 2, 4, 8)\n    num_res_blocks:  int            = 2\n    attn_resolutions:Sequence[int]  = (8,)\n    dropout:         float          = 0.1\n    out_ch:          int            = 3\n\n    @nn.compact\n    def __call__(self, x, t, deterministic=True):\n        # ── timestep embedding ────────────────────────────\n        temb_dim = self.base_ch * 4\n        temb = TimeEmbedding(self.base_ch)(t)   # (B, base_ch*4)\n\n        ch  = self.base_ch\n        chs = [ch * m for m in self.ch_mults]   # channels at each level\n\n        # ── initial projection ────────────────────────────\n        h = nn.Conv(ch, (3, 3), padding=\"SAME\")(x)\n        skips = [h]\n        cur_res = x.shape[1]   # spatial size\n\n        # ── encoder ──────────────────────────────────────\n        for level, out_ch in enumerate(chs):\n            for _ in range(self.num_res_blocks):\n                h = ResBlock(out_ch, self.dropout)(h, temb, deterministic)\n                if cur_res in self.attn_resolutions:\n                    h = SelfAttention()(h)\n                skips.append(h)\n            if level < len(chs) - 1:          # don't downsample at last level\n                h = Downsample(out_ch)(h)\n                cur_res //= 2\n                skips.append(h)\n\n        # ── bottleneck ────────────────────────────────────\n        h = ResBlock(chs[-1], self.dropout)(h, temb, deterministic)\n        h = SelfAttention()(h)\n        h = ResBlock(chs[-1], self.dropout)(h, temb, deterministic)\n\n        # ── decoder ──────────────────────────────────────\n        for level, out_ch in reversed(list(enumerate(chs))):\n            for i in range(self.num_res_blocks + 1):\n                h = jnp.concatenate([h, skips.pop()], axis=-1)\n                h = ResBlock(out_ch, self.dropout)(h, temb, deterministic)\n                if cur_res in self.attn_resolutions:\n                    h = SelfAttention()(h)\n            if level > 0:\n                h = Upsample(out_ch)(h)\n                cur_res *= 2\n\n        # ── final projection to output channels ──────────\n        h = nn.GroupNorm(num_groups=32)(h)\n        h = nn.swish(h)\n        h = nn.Conv(self.out_ch, (3, 3), padding=\"SAME\",\n                    kernel_init=nn.initializers.zeros)(h)\n        return h\n\n\n# ── quick shape test ──────────────────────────────────────────\ndef test_unet():\n    model = UNet(\n        base_ch=C.base_channels,\n        ch_mults=C.channel_mults,\n        num_res_blocks=C.num_res_blocks,\n        attn_resolutions=C.attn_resolutions,\n        dropout=C.dropout,\n        out_ch=C.channels,\n    )\n    dummy_x = jnp.ones((2, C.image_size, C.image_size, C.channels))\n    dummy_t = jnp.array([10, 500])\n    key = random.PRNGKey(0)\n    params = model.init(key, dummy_x, dummy_t)[\"params\"]\n    out    = model.apply({\"params\": params}, dummy_x, dummy_t)\n    n_params = sum(x.size for x in jax.tree_util.tree_leaves(params))\n    print(f\"UNet output shape : {out.shape}\")\n    print(f\"UNet parameters   : {n_params/1e6:.1f}M\")\n    return model, params\n\nmodel, init_params = test_unet()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-20T10:50:57.848627Z","iopub.execute_input":"2026-04-20T10:50:57.848777Z","iopub.status.idle":"2026-04-20T10:53:42.822963Z","shell.execute_reply.started":"2026-04-20T10:50:57.848763Z","shell.execute_reply":"2026-04-20T10:53:42.821875Z"}},"outputs":[{"name":"stdout","text":"UNet output shape : (2, 64, 64, 3)\nUNet parameters   : 253.2M\n","output_type":"stream"}],"execution_count":11},{"cell_type":"code","source":"# ──────────────────────────────────────────────────────────────\n# Training setup (loss, optimizer, train step)\n#